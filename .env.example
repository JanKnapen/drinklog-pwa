# Copy this file to .env and fill in the values before starting the stack.

# JWT secrets — generate with: python -c "import secrets; print(secrets.token_hex(32))"
# WARNING: If these are not set, each process restart generates a new secret and
# invalidates all existing tokens. Always set these in production.
JWT_ACCESS_SECRET=your-access-secret-here
JWT_REFRESH_SECRET=your-refresh-secret-here
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# Seed user (used only when the users table is empty on first startup)
ADMIN_SEED_USERNAME=admin
ADMIN_SEED_PASSWORD=change-me

# Unit divisors (optional, defaults shown)
ALCOHOL_UNIT_DIVISOR=15.0
CAFFEINE_UNIT_DIVISOR=80.0

# --- Dev (Tailscale HTTPS) ---
# Your Tailscale machine hostname (from: tailscale status)
TAILSCALE_HOSTNAME=drinklog-pwa.tailff1db5.ts.net
